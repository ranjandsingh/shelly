<UserControl x:Class="NotchyWindows.Views.SessionTabBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="40" Height="40"
             Background="#FF1E1E1E"
             ClipToBounds="False">
    <DockPanel>
        <!-- Pin button -->
        <Button x:Name="PinButton" DockPanel.Dock="Left"
                Content="&#x1F4CC;" FontSize="11"
                Width="28" Background="Transparent" BorderThickness="0"
                Foreground="#FF888888" Cursor="Hand"
                VerticalContentAlignment="Center"
                Click="PinButton_Click"
                ToolTip="Pin panel"/>

        <!-- Three-dot menu -->
        <Button x:Name="MenuButton" DockPanel.Dock="Right"
                Content="&#x22EE;" FontSize="14" FontWeight="Bold"
                Width="28" Background="Transparent" BorderThickness="0"
                Foreground="#FF888888" Cursor="Hand"
                VerticalContentAlignment="Center"
                Click="MenuButton_Click"
                ToolTip="Menu"/>

        <!-- New tab button -->
        <Button DockPanel.Dock="Right"
                Content="+" FontSize="14" FontWeight="Bold"
                Width="28" Background="Transparent" BorderThickness="0"
                Foreground="#FF888888" Cursor="Hand"
                VerticalContentAlignment="Center"
                Click="NewTab_Click"
                ToolTip="New session"/>

        <!-- Tab list -->
        <ItemsControl x:Name="TabList"
                      ItemsSource="{Binding Sessions}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border x:Name="TabBorder"
                            Padding="10,8" Margin="2,4" Cursor="Hand"
                            CornerRadius="4"
                            MouseLeftButtonUp="Tab_Click">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                        <Setter Property="Background" Value="#FF2A2A2A"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Border.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Rename" Click="RenameTab_Click"/>
                                <MenuItem Header="Close" Click="CloseTab_Click"/>
                            </ContextMenu>
                        </Border.ContextMenu>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Margin="0,0,6,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#FF555555"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="Working">
                                                <Setter Property="Fill" Value="#FFFFA726"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="WaitingForInput">
                                                <Setter Property="Fill" Value="#FF42A5F5"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="TaskCompleted">
                                                <Setter Property="Fill" Value="#FF4CAF50"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Interrupted">
                                                <Setter Property="Fill" Value="#FFEF5350"/>
                                            </DataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Status}" Value="Idle"/>
                                                    <Condition Binding="{Binding IsProjectOpen}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Fill" Value="#FF4CAF50"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="{Binding ProjectName}"
                                       Foreground="#FFE0E0E0" FontSize="12"
                                       VerticalAlignment="Center"/>
                            <!-- Close button: visible when more than 1 session -->
                            <Button Content="&#x2715;" FontSize="9"
                                    Width="16" Height="16" Margin="5,0,0,0"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="#FF666666" Cursor="Hand"
                                    VerticalAlignment="Center"
                                    Click="CloseTabInline_Click"
                                    ToolTip="Close tab">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.Sessions.Count, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="1">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </DockPanel>
</UserControl>
