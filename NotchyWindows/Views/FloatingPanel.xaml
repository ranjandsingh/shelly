<Window x:Class="NotchyWindows.Views.FloatingPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:NotchyWindows.Views"
        Title="Notchy"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="#FF1E1E1E"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        AllowDrop="True">

    <Grid>
        <!-- Collapsed state: small notch indicator -->
        <Border x:Name="CollapsedBar"
                Background="#FF1A1A1A"
                BorderBrush="#FF333333"
                BorderThickness="1,0,1,1"
                CornerRadius="0,0,6,6"
                Padding="10,4"
                Cursor="Hand"
                MouseEnter="CollapsedBar_MouseEnter"
                MouseLeftButtonUp="CollapsedBar_Click">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <!-- Status dot (idle/default) -->
                <Ellipse x:Name="CollapsedStatusDot" Width="8" Height="8"
                         Fill="#FF4CAF50" Margin="0,0,6,0"/>

                <!-- Spinner (working) — spinning arc -->
                <Canvas x:Name="CollapsedSpinner" Width="10" Height="10"
                        Margin="0,0,6,0" Visibility="Collapsed"
                        RenderTransformOrigin="0.5,0.5">
                    <Canvas.RenderTransform>
                        <RotateTransform x:Name="SpinnerRotate" Angle="0"/>
                    </Canvas.RenderTransform>
                    <Path Data="M5,0 A5,5 0 1 1 0,5" Stroke="#FFFFA726"
                          StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                </Canvas>

                <!-- Alert dot (waiting for input) — pulsing -->
                <Ellipse x:Name="CollapsedAlertDot" Width="8" Height="8"
                         Fill="#FFFFA726" Margin="0,0,6,0" Visibility="Collapsed"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <ScaleTransform x:Name="AlertPulse" ScaleX="1" ScaleY="1"/>
                    </Ellipse.RenderTransform>
                </Ellipse>

                <!-- Checkmark (task completed) -->
                <Canvas x:Name="CollapsedCheckmark" Width="10" Height="10"
                        Margin="0,0,6,0" Visibility="Collapsed">
                    <Path Data="M1,5 L4,8 L9,2" Stroke="#FF4CAF50"
                          StrokeThickness="2" StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                </Canvas>

                <TextBlock Text="Terminal"
                           Foreground="#FFE0E0E0" FontSize="11"
                           VerticalAlignment="Center"/>
                <Border x:Name="CollapsedBadge"
                        Background="#FFED8B00"
                        CornerRadius="7"
                        Padding="5,1"
                        Margin="6,0,0,0"
                        Visibility="Collapsed">
                    <TextBlock x:Name="CollapsedBadgeText"
                               Text="2"
                               Foreground="#FFFFFFFF" FontSize="10" FontWeight="Bold"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- Expanded state: full terminal panel -->
        <Border x:Name="ExpandedPanel"
                Background="#FF1E1E1E"
                CornerRadius="0,0,8,8"
                BorderBrush="#FF333333"
                BorderThickness="0"
                Visibility="Collapsed"
                RenderTransformOrigin="0.5,0"
                MouseEnter="ExpandedPanel_MouseEnter"
                MouseLeave="ExpandedPanel_MouseLeave"
                PreviewMouseDown="ExpandedPanel_MouseDown">
            <Border.RenderTransform>
                <TranslateTransform x:Name="ExpandedPanelTranslate" Y="0"/>
            </Border.RenderTransform>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="40" MinHeight="40"/>
                    <RowDefinition Height="1"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Thin drag strip at top -->
                <Border Grid.Row="0" Background="#FF1E1E1E" Cursor="SizeAll"
                        MouseLeftButtonDown="DragBar_MouseLeftButtonDown"/>

                <!-- Tab bar -->
                <views:SessionTabBar Grid.Row="1" x:Name="TabBar"/>

                <!-- Separator -->
                <Border Grid.Row="2" Background="#FF333333"/>

                <!-- Terminal area -->
                <Border Grid.Row="3" Background="#FF1A1A1A">
                    <views:TerminalHostControl x:Name="TerminalHost"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
