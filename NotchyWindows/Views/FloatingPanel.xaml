<Window x:Class="NotchyWindows.Views.FloatingPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:NotchyWindows.Views"
        Title="Notchy"
        Width="720" Height="400"
        MinWidth="480" MinHeight="300"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        ResizeMode="CanResizeWithGrip">
    <Border Background="#FF1E1E1E"
            CornerRadius="0,0,8,8"
            BorderBrush="#FF333333"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top drag bar -->
            <Border Grid.Row="0" Background="#FF111111"
                    MouseLeftButtonDown="DragBar_MouseLeftButtonDown"/>

            <!-- Tab bar area -->
            <views:SessionTabBar Grid.Row="1" x:Name="TabBar"/>

            <!-- Terminal area -->
            <Border Grid.Row="2" Background="#FF1A1A1A">
                <views:TerminalHostControl x:Name="TerminalHost"/>
            </Border>
        </Grid>
    </Border>
</Window>
