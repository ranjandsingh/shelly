<Window x:Class="NotchyWindows.Views.FloatingPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:NotchyWindows.Views"
        Title="Notchy"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="#FF1E1E1E"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        AllowDrop="True">

    <Grid>
        <!-- Collapsed state: small notch indicator -->
        <Border x:Name="CollapsedBar"
                Background="#FF1A1A1A"
                BorderBrush="#FF333333"
                BorderThickness="1,0,1,1"
                CornerRadius="0,0,6,6"
                Padding="10,4"
                Cursor="Hand"
                MouseEnter="CollapsedBar_MouseEnter"
                MouseLeftButtonUp="CollapsedBar_Click">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <Ellipse x:Name="CollapsedStatusDot" Width="8" Height="8"
                         Fill="#FF4CAF50" Margin="0,0,6,0"/>
                <TextBlock Text="Terminal"
                           Foreground="#FFE0E0E0" FontSize="11"
                           VerticalAlignment="Center"/>
                <Border x:Name="CollapsedBadge"
                        Background="#FFED8B00"
                        CornerRadius="7"
                        Padding="5,1"
                        Margin="6,0,0,0"
                        Visibility="Collapsed">
                    <TextBlock x:Name="CollapsedBadgeText"
                               Text="2"
                               Foreground="#FFFFFFFF" FontSize="10" FontWeight="Bold"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- Expanded state: full terminal panel -->
        <Border x:Name="ExpandedPanel"
                Background="#FF1E1E1E"
                CornerRadius="0,0,8,8"
                BorderBrush="#FF333333"
                BorderThickness="0"
                Visibility="Collapsed"
                MouseLeave="ExpandedPanel_MouseLeave"
                PreviewMouseDown="ExpandedPanel_PreviewMouseDown"
                RenderTransformOrigin="0.5,0">
            <Border.RenderTransform>
                <TranslateTransform x:Name="ExpandedPanelTranslate" Y="0"/>
            </Border.RenderTransform>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Tab bar (also serves as drag area via pin button region) -->
                <views:SessionTabBar Grid.Row="0" x:Name="TabBar"
                                     MouseLeftButtonDown="DragBar_MouseLeftButtonDown"/>

                <!-- Terminal area -->
                <Border Grid.Row="1" Background="#FF1A1A1A">
                    <views:TerminalHostControl x:Name="TerminalHost"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
