{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Shelly",
  "version": "0.2.15",
  "identifier": "com.shelly.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Shelly",
        "width": 720,
        "height": 400,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": true,
        "visible": false,
        "skipTaskbar": true
      },
      {
        "label": "notch",
        "title": "",
        "width": 260,
        "height": 52,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "visible": true,
        "skipTaskbar": true,
        "focus": false,
        "url": "notch.html",
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ranjandsingh/shelly/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDcxRjczN0JBQTA1OTlBMUEKUldRYW1sbWd1amYzY1YyV2EyTFlpUWQ5S2p2OG5UTXhMNlNSVEs4b25vZ3Y2bGhBRlVJM0dib3cK"
    }
  }
}
