{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Shelly",
  "version": "0.1.0",
  "identifier": "com.shelly.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Shelly",
        "width": 720,
        "height": 400,
        "decorations": false,
        "transparent": false,
        "alwaysOnTop": true,
        "resizable": true,
        "visible": false,
        "skipTaskbar": true
      },
      {
        "label": "notch",
        "title": "",
        "width": 140,
        "height": 28,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "visible": true,
        "skipTaskbar": true,
        "focus": false,
        "url": "notch.html"
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
