{
  "$schema": "https://opencode.ai/config.json",
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "permission": {
    "read": "allow",
    "edit": "allow",
    "external_directory": "ask",
    "bash": {
      "*": "deny",
      "npm": "allow",
      "npm *": "allow",
      "run": "allow",
      "run *": "allow",
      "git *": "ask",
      "git status": "allow",
      "git status *": "allow",
      "git log": "allow",
      "git log *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git ls-files": "allow",
      "git ls-files *": "allow",
      "git ls-tree": "allow",
      "git ls-tree *": "allow",
      "git worktree": "allow",
      "git worktree *": "allow",
      "git commit": "deny",
      "git commit *": "deny",
      "git push": "deny",
      "git push *": "deny",
      "git add": "deny",
      "git add *": "deny",
      "git reset": "deny",
      "git reset *": "deny",
      "git rebase": "deny",
      "git rebase *": "deny",
      "git merge": "deny",
      "git merge *": "deny"
    }
  }
}